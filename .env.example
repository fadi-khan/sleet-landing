# Resend (https://resend.com) API key used to send transactional emails
RESEND_API_KEY=

# Verified sending domain in Resend, e.g. sleet.sa
# Emails are sent from notifications@<this domain>
RESEND_FROM_DOMAIN=

# Inbox that receives contact/quote form submissions
CONTACT_TO_EMAIL=

# Public site URL, used to build an absolute logo URL for emails
NEXT_PUBLIC_SITE_URL=https://sleet.sa
